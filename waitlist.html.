<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FLOW — Lista de Espera</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #080808;
    --green: #00ff87;
    --green-dim: #00c96a;
    --green-dark: #003d20;
    --green-glow: rgba(0,255,135,0.15);
    --muted: #555;
    --border: #1a1a1a;
    --text: #f0f0f0;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--black);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── BG ─── */
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background:
      radial-gradient(ellipse 50% 60% at 80% 0%, rgba(0,255,135,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 100%, rgba(0,255,135,0.04) 0%, transparent 50%);
    pointer-events:none;
    z-index:0;
  }

  /* ─── GRID LINES ─── */
  body::after {
    content:'';
    position:fixed;
    inset:0;
    background-image:
      linear-gradient(rgba(255,255,255,.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.015) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events:none;
    z-index:0;
  }

  .wrap {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index:1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 60px;
    padding-bottom: 60px;
  }

  /* ─── TOP BAR ─── */
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 32px;
    border-bottom: 1px solid var(--border);
    background: rgba(8,8,8,.8);
    backdrop-filter: blur(20px);
    z-index: 10;
  }
  .topbar-logo {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -1px;
  }
  .topbar-logo span { color: var(--green); }
  .topbar-badge {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--green);
    border: 1px solid var(--green);
    border-radius: 20px;
    padding: 5px 12px;
  }

  /* ─── HERO ─── */
  .eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--green);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .eyebrow::before {
    content:'';
    display:block;
    width: 24px;
    height: 1px;
    background: var(--green);
  }

  h1 {
    font-size: clamp(40px, 10vw, 72px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -2px;
    margin-bottom: 8px;
  }
  h1 .green { color: var(--green); }
  h1 .dim { color: #333; }

  .tagline {
    font-size: clamp(16px, 3vw, 20px);
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 48px;
    max-width: 420px;
  }
  .tagline strong { color: var(--text); }

  /* ─── STATS ─── */
  .stats {
    display: flex;
    gap: 32px;
    margin-bottom: 48px;
  }
  .stat-item { }
  .stat-num {
    font-size: 28px;
    font-weight: 800;
    color: var(--green);
    line-height: 1;
  }
  .stat-label {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 2px;
    margin-top: 4px;
  }

  /* ─── FORM ─── */
  .form-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }
  .form-row {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }
  .form-input {
    flex: 1;
    background: #111;
    border: 1px solid #222;
    border-radius: 10px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    padding: 14px 18px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .form-input:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px var(--green-glow);
  }
  .form-input::placeholder { color: #333; }
  .btn-submit {
    background: var(--green);
    color: #000;
    border: none;
    border-radius: 10px;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 15px;
    padding: 14px 24px;
    cursor: pointer;
    transition: background .15s, box-shadow .2s, transform .1s;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }
  .btn-submit:hover {
    background: #00ffaa;
    box-shadow: 0 0 24px var(--green-glow);
  }
  .btn-submit:active { transform: scale(.97); }
  .form-note {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  /* ─── SUCCESS ─── */
  .success-box {
    display: none;
    background: var(--green-dark);
    border: 1px solid var(--green-dim);
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }
  .success-box.show { display: flex; align-items: center; gap: 16px; }
  .success-icon { font-size: 28px; flex-shrink: 0; }
  .success-title { font-size: 16px; font-weight: 700; color: var(--green); margin-bottom: 4px; }
  .success-msg { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--green-dim); letter-spacing: 1px; }

  /* ─── FEATURES ─── */
  .features {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .features-title {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--muted);
    margin-bottom: 24px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .feature-item {
    background: #0f0f0f;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    transition: border-color .2s;
  }
  .feature-item:hover { border-color: #2a2a2a; }
  .feature-icon { font-size: 20px; margin-bottom: 8px; }
  .feature-name { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .feature-desc { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .feature-badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    letter-spacing: 1px;
    background: var(--green);
    color: #000;
    border-radius: 4px;
    padding: 2px 6px;
    margin-top: 6px;
  }

  /* ─── FOOTER ─── */
  .footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-logo { font-weight: 800; font-size: 14px; }
  .footer-logo span { color: var(--green); }
  .footer-text {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  /* ─── COUNTER ANIMATION ─── */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
  }
  .wrap > * {
    animation: fadeUp .6s ease forwards;
    opacity: 0;
  }
  .wrap > *:nth-child(1) { animation-delay: .1s; }
  .wrap > *:nth-child(2) { animation-delay: .2s; }
  .wrap > *:nth-child(3) { animation-delay: .3s; }
  .wrap > *:nth-child(4) { animation-delay: .4s; }
  .wrap > *:nth-child(5) { animation-delay: .5s; }
  .wrap > *:nth-child(6) { animation-delay: .6s; }

  /* ─── LIVE DOT ─── */
  .live-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    animation: pulse 1.5s infinite;
    margin-right: 4px;
  }
  @keyframes pulse { 0%,100%{opacity:1;}50%{opacity:.3;} }

  @media (max-width: 480px) {
    .features-grid { grid-template-columns: 1fr; }
    .stats { gap: 20px; }
    .form-row { flex-direction: column; }
    .btn-submit { width: 100%; }
  }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-logo">FLOW<span>.</span></div>
  <div class="topbar-badge">PRÓXIMAMENTE</div>
</div>

<div class="wrap">

  <!-- EYEBROW -->
  <div class="eyebrow"><span class="live-dot"></span>Lista de espera abierta</div>

  <!-- HERO -->
  <h1>Construye<br>hábitos<span class="green">.</span><br><span class="dim">Sin excusas.</span></h1>

  <p class="tagline">
    FLOW es la app de hábitos que te <strong>mide, motiva y reta</strong> cada día.
    Próximamente en Play Store — sé de los primeros en acceder.
  </p>

  <!-- STATS -->
  <div class="stats">
    <div class="stat-item">
      <div class="stat-num" id="counter">0</div>
      <div class="stat-label">En lista de espera</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">1.0</div>
      <div class="stat-label">Versión beta</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">Free</div>
      <div class="stat-label">Descarga gratis</div>
    </div>
  </div>

  <!-- FORM -->
  <div>
    <label class="form-label">// Tu correo para el acceso anticipado</label>
    <div class="success-box" id="success-box">
      <div class="success-icon">🔥</div>
      <div>
        <div class="success-title">¡Estás dentro!</div>
        <div class="success-msg">Te avisamos cuando FLOW esté disponible</div>
      </div>
    </div>
    <div id="form-wrap">
      <div class="form-row">
        <input type="email" class="form-input" id="email-input" placeholder="tucorreo@gmail.com">
        <button class="btn-submit" onclick="joinWaitlist()">Unirme →</button>
      </div>
      <div class="form-note">Sin spam. Solo te avisamos cuando esté lista.</div>
    </div>
  </div>

  <!-- FEATURES -->
  <div class="features">
    <div class="features-title">// Lo que viene</div>
    <div class="features-grid">
      <div class="feature-item">
        <div class="feature-icon">⚡</div>
        <div class="feature-name">Sistema XP</div>
        <div class="feature-desc">Gana puntos por cada hábito completado y sube de nivel.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">📈</div>
        <div class="feature-name">Gráficas reales</div>
        <div class="feature-desc">Tu productividad en números. Semanal, mensual y anual.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🏆</div>
        <div class="feature-name">Tabla global</div>
        <div class="feature-desc">Compite con usuarios de todo el mundo por la racha más larga.</div>
        <span class="feature-badge">PRO</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">☁️</div>
        <div class="feature-name">Backup en la nube</div>
        <div class="feature-desc">Tu progreso sincronizado. Cambia de cel sin perder nada.</div>
        <span class="feature-badge">PRO</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🔔</div>
        <div class="feature-name">Alarmas inteligentes</div>
        <div class="feature-desc">Recordatorios exactos a la hora que los necesitas.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">💬</div>
        <div class="feature-name">Frases de líderes</div>
        <div class="feature-desc">Kobe, Musk, Aristóteles. Motivación real al completar tareas.</div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-logo">FLOW<span>.</span></div>
    <div class="footer-text">© 2026 · Hecho con 🔥</div>
  </div>

</div>

<script>
// ─── WAITLIST ──────────────────────────────────────────
let waitlistCount = parseInt(localStorage.getItem('flow_waitlist_count') || '47');

function updateCounter() {
  document.getElementById('counter').textContent = waitlistCount;
}

function joinWaitlist() {
  const email = document.getElementById('email-input').value.trim();
  if (!email || !email.includes('@')) {
    document.getElementById('email-input').style.borderColor = '#ff4d4d';
    setTimeout(() => document.getElementById('email-input').style.borderColor = '', 1500);
    return;
  }

  // Guardar en localStorage
  const emails = JSON.parse(localStorage.getItem('flow_waitlist_emails') || '[]');
  if (emails.includes(email)) {
    document.getElementById('success-box').classList.add('show');
    document.getElementById('form-wrap').style.display = 'none';
    return;
  }
  emails.push(email);
  localStorage.setItem('flow_waitlist_emails', JSON.stringify(emails));
  waitlistCount++;
  localStorage.setItem('flow_waitlist_count', waitlistCount);

  document.getElementById('success-box').classList.add('show');
  document.getElementById('form-wrap').style.display = 'none';
  updateCounter();
}

document.getElementById('email-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') joinWaitlist();
});

// ─── COUNTER ANIMATION ─────────────────────────────────
function animateCounter(target) {
  let current = 0;
  const step = Math.ceil(target / 40);
  const interval = setInterval(() => {
    current = Math.min(current + step, target);
    document.getElementById('counter').textContent = current;
    if (current >= target) clearInterval(interval);
  }, 30);
}

window.addEventListener('load', () => {
  setTimeout(() => animateCounter(waitlistCount), 600);
});
</script>
</body>
</html>
